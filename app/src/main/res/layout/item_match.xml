<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/item_background"
    android:layout_margin="8dp">

    <!-- Match header -->
    <TextView
        android:id="@+id/arenaName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bravida Arena"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="4dp"
        android:textSize="16sp" />

    <!-- Teams and scores -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp">

        <!-- Home team -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/homeTeamLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Home Team Logo"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/homeTeamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home Team"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Match time or score -->
        <TextView
            android:id="@+id/matchTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="8dp"
            android:text="18:00"
            android:textStyle="bold"
            android:textSize="16sp" />

        <!-- Visiting team -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/visitingTeamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visiting Team"
                android:textStyle="bold"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/visitingTeamLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Visiting Team Logo"
                android:paddingStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- League Name -->
    <TextView
        android:id="@+id/leagueName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Allsvenskan"
        android:gravity="center"
        android:textSize="12sp"
        android:paddingTop="4dp"
        android:textColor="@android:color/darker_gray" />
</LinearLayout>

